{
  "name": "origin-trace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "trace": "node --experimental-strip-types src/engine/cli.ts",
